{
  "name": "run_it",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --pool=threads",
    "test:unit": "vitest run tests/unit --pool=threads",
    "test:integration": "vitest run tests/integration --pool=threads",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm run test:integration",
    "prepare": "husky",
    "doctor": "tsx scripts/doctor.ts",
    "regions:fetch": "tsx scripts/fetch_regions.ts",
    "regions:load": "tsx scripts/load_regions.ts",
    "seed": "tsx scripts/seed_fake_users.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@rnmapbox/maps": "^10.3.0",
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.3",
    "supabase": "^2.95.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
