# Copy to .env and fill in.
# These are read from Expo public env vars or pasted directly into app.json -> extra.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
EXPO_PUBLIC_MAPBOX_PUBLIC_TOKEN=pk.eyJ1Ijoi...

# Used only by the @rnmapbox/maps Expo config plugin (not at runtime).
# This is a SECRET token with the DOWNLOADS:READ scope. Do NOT ship it in the bundle.
MAPBOX_DOWNLOADS_TOKEN=sk.eyJ1Ijoi...

# Server-side only. Required by scripts/load_regions.ts and scripts/seed_fake_users.ts.
# NEVER import this anywhere inside the React Native app bundle.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
